extends ../layouts/base.pug
include ../mixins/case-study.pug

block content
  //- ==========================================
  //- PROJECT 01 — Neo Action (project01.pug)
  //- ==========================================

  //- Hero Section — image only
  section#hero.has-media.autoscroll
    #hero-wrapper
      #hero-caption.content-full-width.text-align-default-desktop.dark-section
        .inner
          h1.hero-title.caption-timeline.light-content
            span.word-wrapper
              span Neo Action
          .hero-subtitle.caption-timeline
            span.word-wrapper
              span Built to capture what others miss. We shaped the identity of Neo Action Pro from product logic to visual presence, across CGI, web and motion.
          .hero-infotitle.caption-timeline
            span.word-wrapper
              span.heading-3 2026
      #hero-footer.has-border
        .hero-footer-left
          #scroll-down.button-wrap.button-link.right.circle-edge(data-sticky)
            .icon-wrap
              .icon-effects.parallax-wrap(data-ball-color='primary')
                .button-icon.parallax-element
                  i.fa-solid.fa-arrow-down
            .text-wrap.sticky
              .button-text.parallax-element
                span(data-hover='Scroll to Explore') Scroll to Explore
        .hero-footer-center
          .info-text
            span Created 2026
        .hero-footer-right
          #project-credits.button-wrap.button-link.left.circle-edge.open-modal(data-sticky data-modal-target='#hero-modal' data-modal-direction='right')
            .icon-wrap
              .icon-effects.parallax-wrap(data-ball-color='primary')
                .button-icon.parallax-element
                  i.fa-regular.fa-file
            .text-wrap.sticky
              .button-text.parallax-element
                span(data-hover='Project Credits') Project Credits
    #hero-media.parallax-media
      #hero-media-effects
        #hero-media-wrapper
          img.item-image(src='../images/projects/temp/temp-image-full.jpg' alt='Item Image')
    #hero-modal.modal-source
      .modal-project
        p Client:
        h5 Neo Action Pro
        hr.animated-line
        p Overview:
        p.no-margins
          | We built the visual system around one idea: geometric precision. The camera is a near-perfect cube, so we leaned into that. Concrete, shadow, negative space.
          br
          br
          | Nothing that competes with the object itself. Light was the only storytelling tool, no props, no lifestyle, no context. Just the product and the surface it rests on. Typography followed the same logic: neutral, tight, confident.
        hr
        .button-wrap.button-icon-box.apart-icon.right.rounded-edge.small-btn(data-sticky)
          a(target='_blank' href='http://www.clapat-templates.com/')
            .icon-wrap
              .icon-effects.parallax-wrap
                .button-icon.parallax-element
                  i.fa-solid.fa-arrow-right
            .text-wrap
              .button-text
                span(data-hover='Live Website') Live Website
  
  
  
  
  //- Main Content
  #main-content
    #main-page-content
      //- Row: Client meta + intro text (1/3 + 2/3)
      section.content-row.full.row_padding_top.row_padding_left.row_padding_right.dark-section(data-bgcolor='#111')
        .columns-group
          .one_third
            p(data-animate)
              | Client
              br
              | Neo Systems GmbH
              br
              br
              | Sector
              br
              | Branding, CGI Direction, Motion Guidelines

              br
              br
              | Industry
              br
              | Consumer Electronics
            hr
            hr
          .two_third
            h3.has-mask(data-play-once) What does it mean to be product-led in a saturated market? For Neo Systems it meant starting from the object itself, letting form drive every visual decision, and building a brand that feels as precise as the hardware inside.
            hr
      


      //- Row: Full-width image + two half images
      section.content-row.full.row_padding_top.row_padding_bottom.row_padding_left.row_padding_right.dark-section(data-bgcolor='#111')
        .columns-group
          .one_full
            figure(data-animate)
              a.image-link(href='../images/projects/temp/temp-image-full.jpg')
                img(src='../images/projects/temp/temp-image-full.jpg' alt='Image Title')
