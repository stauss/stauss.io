            .next-project-media-wrapper
              img.item-image(src='../images/projects/temp/temp-image-full.jpg' alt='Item Image')
              .item-video-wrapper
                video.item-video(loop muted playsinline)
                  source(src='../images/02hero.mp4' type='video/mp4')

